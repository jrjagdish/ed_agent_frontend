server {
    listen ${PORT};
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    location / {
        try_files $uri /index.html;
    }

    location /api/ {
        resolver 1.1.1.1 8.8.8.8 valid=30s;

        proxy_pass https://edagent-production-74a4.up.railway.app;
        proxy_ssl_server_name on;
    }
}